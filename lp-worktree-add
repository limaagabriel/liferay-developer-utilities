#!/bin/bash
# filepath: ~/dev/scripts/lp-worktree-add.sh

# Usage: lp-worktree-add.sh [-r <remote-name>] <branch-name>
# Example: lp-worktree-add.sh 7.4.x
#          lp-worktree-add.sh -r upstream 7.4.x

set -e

REMOTE=""

while getopts "r:" opt; do
    case $opt in
        r) REMOTE="$OPTARG" ;;
        *) echo "Usage: $0 [-r <remote-name>] <branch-name>"; exit 1 ;;
    esac
done
shift $((OPTIND - 1))

BRANCH=${1}
BASE_PROJECT_DIR=~/dev/projects
MAIN_REPO_DIR=$BASE_PROJECT_DIR/liferay-portal
BUNDLES_DIR=~/dev/bundles

if [ -z "$BRANCH" ]; then
    echo "Usage: $0 [-r <remote-name>] <branch-name>"
    exit 1
fi

WORKTREE_DIR=$BASE_PROJECT_DIR/liferay-portal-$BRANCH
BUNDLE_DIR=$BUNDLES_DIR/$BRANCH

if [ -n "$REMOTE" ]; then
    REMOTE_BRANCH="$REMOTE/$BRANCH"
    echo "Creating worktree for branch '$BRANCH' from remote '$REMOTE_BRANCH'..."
    git -C "$MAIN_REPO_DIR" worktree add --track -b "$BRANCH" "$WORKTREE_DIR" "$REMOTE_BRANCH"
else
    echo "Creating worktree for branch '$BRANCH'..."
    git -C "$MAIN_REPO_DIR" worktree add "$WORKTREE_DIR" "$BRANCH"
fi

echo "Creating app.server.me.properties..."
cat > "$WORKTREE_DIR/app.server.me.properties" <<EOF
app.server.parent.dir=$BUNDLE_DIR
EOF

echo "Done! Worktree ready at $WORKTREE_DIR"

source lp-worktree-cd "$BRANCH"
