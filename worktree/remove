#!/bin/bash
# Usage: lp worktree remove <branch-name>

set -e

source "$(dirname "${BASH_SOURCE[0]}")/../config"

BRANCH=$1

if [ -z "$BRANCH" ]; then
    echo "Usage: lp worktree remove <branch-name>"
    exit 1
fi

lp_branch_vars "$BRANCH"

read -p "Remove worktree '$WORKTREE_DIR' and bundle '$BUNDLE_DIR'? [y/N] " confirm
if [[ "$confirm" != "y" ]]; then
    echo "Aborted."
    exit 0
fi

echo "Removing worktree..."
git -C "$MAIN_REPO_DIR" worktree remove "$WORKTREE_DIR" --force

echo "Removing bundle directory..."
rm -rf "$BUNDLE_DIR"

echo "Done!"
