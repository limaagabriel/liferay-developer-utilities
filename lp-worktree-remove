#!/bin/bash
# filepath: ~/dev/scripts/lp-worktree-remove.sh

# Usage: lp-worktree-remove.sh <branch-name>

set -e

BRANCH=$1
BASE_PROJECT_DIR=~/dev/projects
MAIN_REPO_DIR=$BASE_PROJECT_DIR/liferay-portal
BUNDLES_DIR=~/dev/bundles

if [ -z "$BRANCH" ]; then
    echo "Usage: $0 <branch-name>"
    exit 1
fi

WORKTREE_DIR=$BASE_PROJECT_DIR/liferay-portal-$BRANCH
BUNDLE_DIR=$BUNDLES_DIR/$BRANCH

read -p "Remove worktree '$WORKTREE_DIR' and bundle '$BUNDLE_DIR'? [y/N] " confirm
if [[ "$confirm" != "y" ]]; then
    echo "Aborted."
    exit 0
fi

echo "Removing worktree..."
git -C "$MAIN_REPO_DIR" worktree remove "$WORKTREE_DIR" --force

echo "Removing bundle directory..."
rm -rf "$BUNDLE_DIR"

echo "Done!"