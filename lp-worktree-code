#!/bin/bash
# filepath: ~/dev/scripts/lp-code.sh

# Usage: lp-code <branch-name>

BRANCH=$1
BASE_PROJECT_DIR=~/dev/projects

if [ -z "$BRANCH" ]; then
    echo "Usage: $0 <branch-name>"
    exit 1
fi

WORKTREE_DIR=$BASE_PROJECT_DIR/liferay-portal-$BRANCH

if [ ! -d "$WORKTREE_DIR" ]; then
    echo "Worktree '$WORKTREE_DIR' does not exist."
    exit 1
fi

code "$WORKTREE_DIR"